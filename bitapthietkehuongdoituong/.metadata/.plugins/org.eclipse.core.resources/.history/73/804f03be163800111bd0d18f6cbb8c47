package baitaptuan5;

	public class DiGraph extends Graph {

		@Override
		public void addEdge(int v1, int v2) {
			// TODO Auto-generated method stub
			if (!isValidVertex(v1) || !isValidVertex(v2))
				return;
			adjacencyMatrix[v1][v2] = 1; // thêm cung
		}

		@Override
		public void removeEdge(int v1, int v2) {
			// TODO Auto-generated method stub
			if (!isValidVertex(v1) || !isValidVertex(v2))
				return;
			adjacencyMatrix[v1][v2] = 0; // xóa cung

		}

		// có hướng đếm dòng là bậc ra đếm cột là bậc vào
		public int outDegree(int v) {
			// TODO Auto-generated method stub
			int deg = 0;
			for (int i = 0; i < numVertices; i++) {
				deg += adjacencyMatrix[v][i];

			}
			return deg;

		}

		public int inDegree(int v) {
			int deg = 0;
			for (int i = 0; i < numVertices; i++) {
				deg += adjacencyMatrix[i][v];

			}
			return deg;

		}

		public int deg(int v) {
			return inDegree(v) + outDegree(v);
		}
		// số cạnh của đồ thị bằng tổng các số 1 trong ma trận kề vì cạnh u-->v chỉ xuất
		// hiện 1 lần

		@Override
		public int numEdges() {
			// TODO Auto-generated method stub
			int sum = 0;
			for (int i = 0; i < numVertices; i++) {
				for (int j = 0; j < numVertices; j++) {
					sum += adjacencyMatrix[i][j];

				}

			}

			return sum;
		}

		@Override
		public int sumDeg() {
			// TODO Auto-generated method stub
			int sum = 0;
			for (int i = 0; i < numVertices; i++) {
				sum += deg(i);

			}
			if (sum == 2 * numEdges()) {
				System.out.println("Đúng định lý tổng bậc = 2 * số cạnh");
			} else {
				System.out.println("làm sai phần nào đó rồi");
			}
			return sum;
		}

		@Override
		public boolean isConnected() {
			// strongly connected: liên thông mạnh : u->v, v-> u

			// TODO Auto-generated method stub
			// liên thông mạnh
			for (int i = 0; i < numVertices; i++) {
				DFS(i, false);

				for (int j = 0; j < numVertices; j++) {
					if (!visited[j]) {
						return false;
					}

				}
				

			}
			return true;
		}

		// liên thông yếu: vô hướng liên thông
		
		public boolean isWeaklyConnected() {
			for (int i = 0; i < numVertices; i++) {
				DFS(i, true);
				if (!visited[i]) {
					return false;
				}
			}
			return true;

		}

