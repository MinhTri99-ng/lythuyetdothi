package baitaptuan5;

import java.util.ArrayList;
import java.util.List;
import java.util.Stack;

public class DiGraph extends Graph {

		@Override
		public void addEdge(int v1, int v2) {
			// TODO Auto-generated method stub
			if (!isValidVertex(v1) || !isValidVertex(v2))
				return;
			adjacencyMatrix[v1][v2] = 1; // thêm cung
		}

		@Override
		public void removeEdge(int v1, int v2) {
			// TODO Auto-generated method stub
			if (!isValidVertex(v1) || !isValidVertex(v2))
				return;
			adjacencyMatrix[v1][v2] = 0; // xóa cung

		}

		// có hướng đếm dòng là bậc ra đếm cột là bậc vào
		public int outDegree(int v) {
			// TODO Auto-generated method stub
			int deg = 0;
			for (int i = 0; i < numVertices; i++) {
				deg += adjacencyMatrix[v][i];

			}
			return deg;

		}

		public int inDegree(int v) {
			int deg = 0;
			for (int i = 0; i < numVertices; i++) {
				deg += adjacencyMatrix[i][v];

			}
			return deg;

		}

		public int deg(int v) {
			return inDegree(v) + outDegree(v);
		}
		// số cạnh của đồ thị bằng tổng các số 1 trong ma trận kề vì cạnh u-->v chỉ xuất
		// hiện 1 lần

		@Override
		public int numEdges() {
			// TODO Auto-generated method stub
			int sum = 0;
			for (int i = 0; i < numVertices; i++) {
				for (int j = 0; j < numVertices; j++) {
					sum += adjacencyMatrix[i][j];

				}

			}

			return sum;
		}

		@Override
		public int sumDeg() {
			// TODO Auto-generated method stub
			int sum = 0;
			for (int i = 0; i < numVertices; i++) {
				sum += deg(i);

			}
			if (sum == 2 * numEdges()) {
				System.out.println("Đúng định lý tổng bậc = 2 * số cạnh");
			} else {
				System.out.println("làm sai phần nào đó rồi");
			}
			return sum;
		}
		@Override
		public boolean isConnected() {
			if (numVertices == 0) return true;
		    int[] res = DFS(0);
		    return res.length == numVertices;
		}

		@Override
		public int[] DFS(int startVertex) {
			boolean[] visited = new boolean[numVertices];
		    List<Integer> result = new ArrayList<>();
		    Stack<Integer> stack = new Stack<>();
		    
		    stack.push(startVertex);
		    while (!stack.isEmpty()) {
		        int v = stack.pop();
		        if (!visited[v]) {
		            visited[v] = true;
		            result.add(v);
		            for (int i = numVertices - 1; i >= 0; i--) {
		                if (adjacencyMatrix[v][i] == 1 && !visited[i]) stack.push(i);
		            }
		        }
		    }
		    return result.stream().mapToInt(i -> i).toArray();
		}
}
